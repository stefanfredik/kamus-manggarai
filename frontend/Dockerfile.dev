# Development image running the Vite dev server with HMR.
FROM node:20-alpine

WORKDIR /app

# Install dependencies first for better layer caching.
COPY package*.json ./
RUN npm install

# Source is bind-mounted at runtime; copy as fallback for standalone builds.
COPY . .

EXPOSE 5173

# --host exposes the dev server outside the container; HMR over the mapped port.
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]
