# ============================================================
# KAMUS MANGGARAI — Production Environment Template
# Domain: kamus.florescyber.tech
#
# CARA PAKAI:
#   cp .env.production.example .env
#   nano .env   ← isi semua nilai yang ditandai WAJIB DIUBAH
# ============================================================

# Application
APP_ENV=production
APP_PORT=8080
APP_URL=https://kamus.florescyber.tech
FRONTEND_URL=https://kamus.florescyber.tech

# Database — WAJIB DIUBAH: gunakan password yang kuat
DB_HOST=postgres
DB_PORT=5432
DB_NAME=kamus_manggarai
DB_USER=kamus_user
DB_PASSWORD=GANTI_DENGAN_PASSWORD_DATABASE_KUAT
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m

# Redis — WAJIB DIUBAH: gunakan password yang kuat
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=GANTI_DENGAN_PASSWORD_REDIS_KUAT
REDIS_DB=0

# JWT — WAJIB DIUBAH: generate dengan: openssl rand -base64 64
JWT_ACCESS_SECRET=GANTI_DENGAN_STRING_ACAK_PANJANG_MIN_64_KARAKTER
JWT_REFRESH_SECRET=GANTI_DENGAN_STRING_ACAK_LAIN_MIN_64_KARAKTER
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Google OAuth — WAJIB DIUBAH: sesuaikan dengan domain production
# Tambahkan juga di Google Cloud Console:
#   Authorized redirect URIs: https://kamus.florescyber.tech/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=MASUKKAN_GOOGLE_CLIENT_ID_ANDA
GOOGLE_CLIENT_SECRET=MASUKKAN_GOOGLE_CLIENT_SECRET_ANDA
GOOGLE_REDIRECT_URL=https://kamus.florescyber.tech/api/v1/auth/google/callback

# Rate Limiting (requests per minute)
RATE_LIMIT_PUBLIC=60
RATE_LIMIT_AUTH=10

# Logging
LOG_LEVEL=warn
LOG_FORMAT=json

# Seeder admin — WAJIB DIUBAH
SEED_ADMIN_EMAIL=admin@florescyber.tech
SEED_ADMIN_NAME=Administrator
