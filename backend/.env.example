# Application
APP_ENV=development
APP_PORT=8080
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=kamus_manggarai
DB_USER=kamus_user
DB_PASSWORD=kamus_pass_dev
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass_dev
REDIS_DB=0

# JWT
JWT_ACCESS_SECRET=change_me_in_production_to_a_strong_random_string
JWT_REFRESH_SECRET=change_me_in_production_to_another_strong_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# Rate Limiting
RATE_LIMIT_PUBLIC=60
RATE_LIMIT_AUTH=10

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Seeder admin
SEED_ADMIN_EMAIL=admin@kamus-manggarai.id
SEED_ADMIN_NAME=Administrator
